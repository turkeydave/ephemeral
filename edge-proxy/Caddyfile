# VM-side edge proxy.
#
# Listens on :8080 (the only port the VM exposes to the gateway). Routes
# requests by Host header:
#   <env>-app.*  -> app    (nginx, port 80)
#   <env>-api.*  -> api    (express, port 3001)
#
# /healthz is served unconditionally for the gateway readiness check.
#
# Logging is on so we can see what hostnames the gateway is sending.

{
	admin off
	auto_https off
	log {
		output stdout
		format console
	}
}

:8080 {
	@app       host *-app.*
	@api       host *-api.*
	@firestore host *-firestore.*

	handle /healthz {
		respond "ok" 200
	}

	handle @app {
		reverse_proxy app:80
	}

	handle @api {
		reverse_proxy api:3001
	}

	# Firestore emulator. Browser SDK is configured (in app/main.js) to
	# talk here, so each ephemeral env has its own emulator-backed
	# Firestore instead of sharing a real GCP one.
	#
	# Firestore's JS SDK uses long polling and (optionally) WebChannel
	# over HTTP — Caddy proxies both transparently. Buffering is disabled
	# to keep the long-poll stream live.
	handle @firestore {
		reverse_proxy firebase-emulator:8080 {
			flush_interval -1
		}
	}

	handle {
		respond "edge-proxy: no host match (expected *-app.* / *-api.* / *-firestore.*)" 404
	}
}
